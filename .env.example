# Copy to .env and fill in. Never commit the real .env file.
#
# Supabase project settings -> Database -> Connection string.
# Use the "Session pooler" or direct connection (NOT the transaction
# pooler on 6543) — dbt runs DDL (CREATE TABLE) which the transaction
# pooler doesn't support reliably.
SUPABASE_DB_HOST=db.xxxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres
SUPABASE_DB_SCHEMA=analytics

# Only used for scripts/ that read via the Supabase client instead of raw SQL.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used by scripts/send_daily_email.py (see .github/workflows/daily-email.yml
# for the scheduled version). Get RESEND_API_KEY from resend.com/api-keys —
# use a key scoped to this project, separate from trending-now's.
RESEND_API_KEY=
DAILY_EMAIL_FROM=analytics@trendstamp.com
DAILY_EMAIL_TO=
